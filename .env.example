# ═══════════════════════════════════════════════
# SmoothSend API Key (required)
# ═══════════════════════════════════════════════
# Get one at https://dashboard.smoothsend.xyz
# sk_ for backend/scripts, pk_ for browser frontends
SMOOTHSEND_API_KEY=sk_nogas_your_key_here

# ═══════════════════════════════════════════════
# EOA Private Key (optional - reuses same wallet)
# ═══════════════════════════════════════════════
PRIVATE_KEY=0x_your_eoa_private_key_here

# ═══════════════════════════════════════════════
# Network (optional)
# ═══════════════════════════════════════════════
# avalanche-fuji (default) | avalanche-mainnet
NETWORK=avalanche-fuji

# ═══════════════════════════════════════════════
# Gemini API Key (optional - AI agent demo)
# ═══════════════════════════════════════════════
# Free at https://aistudio.google.com/
GEMINI_API_KEY=xxx
