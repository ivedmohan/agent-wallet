# SmoothSend API key (required - get one at dashboard.smoothsend.xyz)
# Use sk_ for backend/agents, pk_ for frontend/demos
SMOOTHSEND_API_KEY=sk_nogas_xxx

# Gemini API key (optional - for AI agent demo, free at aistudio.google.com)
GEMINI_API_KEY=xxx

# Network (avalanche-fuji or avalanche-mainnet)
NETWORK=avalanche-fuji

# x402 demo API base URL
X402_API_URL=http://localhost:3030
