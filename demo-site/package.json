{
  "name": "demo-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:local": "npm run link:wallet 2>/dev/null; npm run rebuild:wallet && next dev",
    "link:wallet": "npm link @vedmohan/agent-wallet",
    "unlink:wallet": "npm unlink --no-save @vedmohan/agent-wallet && npm install",
    "rebuild:wallet": "cd ../ && npm run build 2>&1 | tail -3",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@vedmohan/agent-wallet": "file:..",
    "next": "^15.0.0",
    "viem": "^2.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0"
  }
}
