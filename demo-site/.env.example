# Required: SmoothSend API key (get one at https://dashboard.smoothsend.xyz)
SMOOTHSEND_API_KEY=sk_nogas_your_key_here

# Optional: Network (default: avalanche-fuji)
# WALLET_NETWORK=avalanche-fuji

# Optional: Daily spending limit (default: 100 USDC)
# WALLET_DAILY_LIMIT=100

# Optional: Per-transaction limit (default: 10 USDC)
# WALLET_PER_TX_LIMIT=10
