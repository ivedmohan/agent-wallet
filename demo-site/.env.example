# ═══════════════════════════════════════════════════════════════
# Required: SmoothSend API Key
# ═══════════════════════════════════════════════════════════════
# Get one at https://dashboard.smoothsend.xyz
# Use sk_ (secret key) for server-side (API routes / backend)
# For Vercel: API routes run server-side, so sk_ is correct
SMOOTHSEND_API_KEY=sk_nogas_your_key_here

# ═══════════════════════════════════════════════════════════════
# Required: EOA Private Key (reuses the same funded wallet)
# ═══════════════════════════════════════════════════════════════
# Without this, every visitor creates a NEW random wallet with $0
# Paste the private key from when you created the funded wallet
# Export from code: wallet.exportPrivateKey()
PRIVATE_KEY=0x_your_eoa_private_key_here

# ═══════════════════════════════════════════════════════════════
# Optional: Network
# ═══════════════════════════════════════════════════════════════
# avalanche-fuji | avalanche-mainnet
# Default: avalanche-fuji
WALLET_NETWORK=avalanche-fuji

# ═══════════════════════════════════════════════════════════════
# Optional: Budget limits (in USDC)
# ═══════════════════════════════════════════════════════════════
WALLET_DAILY_LIMIT=100
WALLET_PER_TX_LIMIT=10
